# Copy this file to .env and fill in only what you need.
# Nothing here is required for core search + lyrics-assist to work.
# Missing values for a feature you haven't enabled just leave that
# feature inactive — see docs/refrain-architecture.md Section 4.1.

PROPRESENTER_API_KEY=

# --- Planning Center (only needed if role=logger and provider=planning-center) ---
PLANNING_CENTER_APP_ID=
PLANNING_CENTER_SECRET=

# --- Firestore (only needed if storageBackend=firestore) ---
FIRESTORE_PROJECT_ID=
# Logger machine only — reader machines don't need this at all.
FIRESTORE_SERVICE_ACCOUNT_KEY_PATH=

# --- SFTP (only needed if storageBackend=sftp — self-hosted alternate) ---
SFTP_HOST=
SFTP_USERNAME=
SFTP_PRIVATE_KEY_PATH=
SFTP_KNOWN_HOST_FINGERPRINT=
